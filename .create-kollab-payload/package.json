{
  "name": "create-kollab-payload",
  "version": "1.0.6",
  "description": "Generate a Kollab Payload CMS + Next.js client site from the kollab-payload-template (internal Kollab tool).",
  "type": "module",
  "license": "MIT",
  "bin": {
    "create-kollab-payload": "dist/index.js"
  },
  "files": [
    "dist",
    "engine"
  ],
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "bundle-engine": "tsx scripts/bundle-engine.ts",
    "build": "npm run bundle-engine && tsc",
    "dev": "npm run bundle-engine && tsx src/index.ts",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "prompts": "^2.4.2",
    "ts-morph": "^28.0.0",
    "tsx": "^4.20.5"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/prompts": "^2.4.9",
    "typescript": "^5.6.0"
  }
}
