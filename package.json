{
  "name": "kollab-payload-template",
  "version": "1.0.0",
  "description": "Website template for PayloadCMS created for Kollab Solutions",
  "license": "MIT",
  "type": "module",
  "packageManager": "yarn@1.22.22",
  "scripts": {
    "attach": "docker attach $(docker compose ps -q payload)",
    "attach:ps": "powershell -Command \"docker attach $(docker compose ps --quiet payload | Select-Object -First 1)\"",
    "build": "cross-env NODE_OPTIONS=--no-deprecation next build",
    "postbuild": "next-sitemap --config next-sitemap.config.cjs",
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev -p ${PORT:-8890}",
    "_generate:importmap": "cross-env NODE_OPTIONS='--import ./scss-loader.mjs --no-deprecation' node ./node_modules/.bin/payload generate:importmap",
    "generate:importmap": "docker compose exec payload yarn _generate:importmap",
    "_generate:types": "cross-env NODE_OPTIONS='--import ./scss-loader.mjs --no-deprecation' node ./node_modules/.bin/payload generate:types",
    "generate:types": "docker compose exec payload yarn _generate:types",
    "_migrate:create": "yarn payload migrate:create",
    "migrate:create": "docker compose exec payload yarn _migrate:create",
    "lint": "cross-env NODE_OPTIONS=--no-deprecation next lint",
    "lint:fix": "cross-env NODE_OPTIONS=--no-deprecation next lint --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "payload": "cross-env NODE_OPTIONS='--import ./scss-loader.mjs --no-deprecation' payload",
    "reinstall": "cross-env NODE_OPTIONS=--no-deprecation rm -rf node_modules && rm yarn.lock && yarn install",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "cli": "tsx .cli/lib/core.ts",
    "docker-dev": "docker compose up payload",
    "docker-prod": "docker compose -f docker-compose.prod.yml up",
    "docker-prod:build": "docker compose -f docker-compose.prod.yml build",
    "docker-prod:down": "docker compose -f docker-compose.prod.yml down",
    "docker-prod:up-build": "docker compose -f docker-compose.prod.yml up --build"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@payloadcms/admin-bar": "3.86.0",
    "@payloadcms/db-postgres": "3.86.0",
    "@payloadcms/email-nodemailer": "3.86.0",
    "@payloadcms/live-preview-react": "3.86.0",
    "@payloadcms/next": "3.86.0",
    "@payloadcms/plugin-form-builder": "3.86.0",
    "@payloadcms/plugin-nested-docs": "3.86.0",
    "@payloadcms/plugin-redirects": "3.86.0",
    "@payloadcms/plugin-search": "3.86.0",
    "@payloadcms/plugin-seo": "3.86.0",
    "@payloadcms/richtext-lexical": "3.86.0",
    "@payloadcms/translations": "^3.86.0",
    "@payloadcms/ui": "3.86.0",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@tabler/icons-react": "^3.39.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cross-env": "^10.1.0",
    "css-loader": "^7.1.4",
    "dotenv": "^17.4.1",
    "geist": "^1.7.0",
    "graphql": "^16.13.2",
    "lucide-react": "1.7.0",
    "next": "16.2.11",
    "next-intl": "^4.9.0",
    "next-sitemap": "^4.2.3",
    "payload": "3.86.0",
    "payload-lexical-typography": "^0.5.2",
    "postcss-loader": "^8.2.0",
    "prism-react-renderer": "^2.4.1",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-hook-form": "^7.72.1",
    "react-phone-number-input": "^3.4.16",
    "recharts": "^3.7.0",
    "sass-loader": "^16.0.7",
    "sharp": "^0.34.5",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "yjs": "^13.6.29"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.4",
    "@tailwindcss/postcss": "^4.2.1",
    "@tailwindcss/typography": "^0.5.19",
    "@types/escape-html": "^1.0.4",
    "@types/node": "24.5.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "autoprefixer": "^10.4.27",
    "copyfiles": "^2.4.1",
    "eslint": "^10.2.0",
    "eslint-config-next": "16.2.3",
    "npm-check-updates": "^20.0.0",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "sass": "1.62.1",
    "tailwindcss": "^4.2.1",
    "ts-morph": "^28.0.0",
    "tsx": "^4.20.5",
    "typescript": "5.9.2",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=20.9.0"
  },
  "resolutions": {
    "@types/react": "19.2.13",
    "@types/react-dom": "19.2.3"
  }
}
