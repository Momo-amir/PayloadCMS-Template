{
  "name": "kollab-payload-template",
  "version": "1.0.0",
  "description": "Website template for PayloadCMS created for Kollab Solutions",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "attach": "docker attach $(docker compose ps -q payload)",
    "build": "cross-env NODE_OPTIONS=--no-deprecation next build",
    "postbuild": "next-sitemap --config next-sitemap.config.cjs",
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev -p ${PORT:-8890}",
    "dev:prod": "cross-env NODE_OPTIONS=--no-deprecation rm -rf .next && yarn build && yarn start",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "ii": "cross-env NODE_OPTIONS=--no-deprecation yarn install",
    "lint": "cross-env NODE_OPTIONS=--no-deprecation next lint",
    "lint:fix": "cross-env NODE_OPTIONS=--no-deprecation next lint --fix",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "dev:migrate": "yarn payload migrate && yarn dev",
    "ci": "yarn payload migrate && yarn build",
    "reinstall": "cross-env NODE_OPTIONS=--no-deprecation rm -rf node_modules && rm yarn.lock && yarn install",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "cli": "tsx .cli/lib/core.ts",
    "docker-dev": "docker compose up payload",
    "docker-prod": "docker compose -f docker-compose.prod.yml up",
    "docker-prod:build": "docker compose -f docker-compose.prod.yml up --build",
    "docker-prod:down": "docker compose -f docker-compose.prod.yml down",
    "docker-prod:logs": "docker compose -f docker-compose.prod.yml logs -f",
    "deploy-prod": "./deploy-production.sh"
  },
  "dependencies": {
    "@lexical/react": "^0.35.0",
    "@payloadcms/admin-bar": "3.56.0",
    "@payloadcms/db-postgres": "3.56.0",
    "@payloadcms/email-nodemailer": "3.56.0",
    "@payloadcms/live-preview-react": "3.56.0",
    "@payloadcms/next": "3.56.0",
    "@payloadcms/payload-cloud": "3.56.0",
    "@payloadcms/plugin-form-builder": "3.56.0",
    "@payloadcms/plugin-nested-docs": "3.56.0",
    "@payloadcms/plugin-redirects": "3.56.0",
    "@payloadcms/plugin-search": "3.56.0",
    "@payloadcms/plugin-seo": "3.56.0",
    "@payloadcms/richtext-lexical": "3.56.0",
    "@payloadcms/ui": "3.56.0",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.3",
    "@tabler/icons-react": "^3.34.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cross-env": "^10.0.0",
    "css-loader": "^7.1.2",
    "dotenv": "^17.2.2",
    "geist": "^1.5.1",
    "graphql": "^16.11.0",
    "lucide-react": "^0.544.0",
    "next": "15.5.4",
    "next-sitemap": "^4.2.3",
    "payload": "3.56.0",
    "postcss-loader": "^8.2.0",
    "prism-react-renderer": "^2.4.1",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-hook-form": "^7.62.0",
    "sass-loader": "^16.0.5",
    "sharp": "^0.34.3",
    "tailwind-merge": "^3.3.1",
    "tailwindcss-animate": "^1.0.7",
    "yjs": "^13.6.27"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@tailwindcss/postcss": "^4.1.13",
    "@tailwindcss/typography": "^0.5.16",
    "@types/escape-html": "^1.0.4",
    "@types/node": "24.5.2",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "autoprefixer": "^10.4.21",
    "copyfiles": "^2.4.1",
    "eslint": "^9.35.0",
    "eslint-config-next": "^15.5.3",
    "npm-check-updates": "^18.0.3",
    "postcss": "^8.5.6",
    "prettier": "^3.6.2",
    "sass": "1.62.1",
    "tailwindcss": "^4.1.13",
    "tsx": "^4.20.5",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": "^18.20.2 || >=20.9.0"
  }
}
