# This is an example .env file for the Kollab Website Template.
DATABASE_URI=postgres://postgres:supersecret@postgres:5432/kollab-website-template
PAYLOAD_SECRET=86730cfcabf26a7275055499
NEXT_PUBLIC_SERVER_URL=http://localhost:8890
CRON_SECRET=YOUR_CRON_SECRET_HERE
PREVIEW_SECRET=YOUR_SECRET_HERE

# PostgreSQL configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=supersecret
POSTGRES_DB=kollab-website-template

# Admin user credentials
ADMIN_EMAIL=admin@kollab.dk
ADMIN_PASSWORD=admin123

# Email configuration
MAIL_ENABLED=false
MAIL_SECURE=false
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USER=your_example_username
MAIL_PASS=your_example_password
MAIL_FROM_ADDRESS=info@example.com
MAIL_FROM_NAME=Kollab

# Analytics configuration (GDPR-compliant)
# Google Analytics (GA4) - Get your ID from: https://analytics.google.com/
NEXT_PUBLIC_GA_MEASUREMENT_ID=
# Google Tag Manager - Get your ID from: https://tagmanager.google.com/
NEXT_PUBLIC_GTM_MEASUREMENT_ID=

GA4_API_SECRET=

MATOMO_URL?=
MATOMO_SITE_ID?=

ANALYTICS_TRUSTED_ORIGINS=http://localhost:3000,http://localhost:8890