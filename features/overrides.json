{
  "$schema": "./overrides.schema.json",
  "_note": "Maintainer-owned. Auto-discovery derives most feature metadata from block/collection configs and static imports. Add an entry here ONLY for facts code cannot express: plugin/collection prerequisites (bare relationTo strings), grouping, and sub-block markers. A slug absent from this file is fine.",
  "blocks": {
    "archiveBlock": {
      "group": "Content",
      "requiresCollections": ["posts", "categories"]
    },
    "peopleArchiveBlock": {
      "group": "Content",
      "requiresCollections": ["people"]
    },
    "formBlock": {
      "group": "Forms",
      "requiresPlugins": ["@payloadcms/plugin-form-builder"],
      "requiresCollections": ["forms"]
    },
    "mediaBlock": {
      "group": "Media",
      "requiresCollections": ["media"]
    },
    "cardBlock": {
      "group": "Content",
      "requiresCollections": ["media"]
    },
    "cardCarouselBlock": {
      "group": "Content",
      "requiresCollections": ["media"]
    },
    "userLoginBlock": {
      "group": "Account"
    },
    "richTextBlock": {
      "group": "Layout",
      "onlyInside": "twoColumnBlock"
    },
    "bannerBlock": {
      "group": "Content",
      "inlineOnly": true
    },
    "codeBlock": {
      "group": "Content",
      "inlineOnly": true
    },
    "columnsBlock": {
      "group": "Layout"
    },
    "twoColumnBlock": {
      "group": "Layout"
    }
  }
}
