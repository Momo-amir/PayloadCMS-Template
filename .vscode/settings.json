{
  "npm.packageManager": "yarn",
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.fixAll.eslint": "explicit"
    }
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.fixAll.eslint": "explicit"
    }
  },
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.fixAll.eslint": "explicit"
    }
  },
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true
  },
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true
  },
  "editor.formatOnSaveMode": "file",
  "typescript.tsdk": "node_modules/typescript/lib",
  "[javascript][typescript][typescriptreact]": {
    "editor.codeActionsOnSave": {
      "source.fixAll.eslint": "explicit"
    }
  },
  "folder-color.pathColors": [],
  "files.exclude": {
    "**/.git": false,
    "**/.svn": false,
    "**/.hg": false,
    "**/.DS_Store": false,
    "**/Thumbs.db": false,
    "**/CVS": false,
    "utilities": false,
    "redirects.js": false,
    "components.json": false,
    "*.json": false,
    "postcss.config.js": false,
    ".editorconfig": false,
    "**/.editorconfig": false,
    "**/.gitignore": false,
    ".gitignore": false,
    "**/eslint.config.mjs": false,
    "**/docker-compose.yml": false,
    "*.yml": false,
    "docker-compose.yml": false,
    "Dockerfile": false,
    "**/.npmrc": false,
    "**/.prettierignore": false,
    ".prettierignore": false,
    "**/environment.d.ts": false,
    "**/cssVariables.js": false,
    "**/next-env.d.ts": false,
    "**/node_modules": false,
    "**/next-sitemap.config.cjs": false
  },
  "explorerExclude.backup": {}
}
