{
  "npm.packageManager": "pnpm",
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.fixAll.eslint": "explicit"
    }
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.fixAll.eslint": "explicit"
    }
  },
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.fixAll.eslint": "explicit"
    }
  },
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true
  },
  "[jsonc]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.formatOnSave": true
  },
  "editor.formatOnSaveMode": "file",
  "typescript.tsdk": "node_modules/typescript/lib",
  "[javascript][typescript][typescriptreact]": {
    "editor.codeActionsOnSave": {
      "source.fixAll.eslint": "explicit"
    }
  },
  "folder-color.pathColors": [],
  "files.exclude": {
    "**/.git": true,
    "**/.svn": true,
    "**/.hg": true,
    "**/CVS": true,
    "**/.DS_Store": true,
    "**/Thumbs.db": true,
    "utilities": true,
    "redirects.js": true,
    "components.json": true,
    "*.json": true,
    "postcss.config.js": true,
    "**/hackerthon-kollab-website.db": true,
    ".editorconfig": true,
    "**/.editorconfig": true,
    "**/.gitignore": true,
    ".gitignore": true,
    "**/eslint.config.mjs": true,
    "**/docker-compose.yml": true,
    "*.yml": true,
    "docker-compose.yml": true,
    "Dockerfile": true,
    "**/.npmrc": true,
    "**/.prettierignore": true,
    ".prettierignore": true,
    "**/environment.d.ts": true,
    "**/cssVariables.js": true,
    "**/next-env.d.ts": true,
    "**/node_modules": true,
    "**/next-sitemap.config.cjs": true
  },
  "explorerExclude.backup": {}
}
